    <!-- ===================== LEGEND / LOOP NOTE ===================== -->
    <mxCell id="lg" value="The demo spine (the loop): B telemetry  →  D labels / retrain  →  C signed redeploy  →  back to the device.&#10;Minimization happens twice: by construction on-device (firmware emits only inference); by policy at the gateway (Vector enforces + audits; raw + features dropped). Data minimization / CRA.&#10;Demo: device simulated by fakegen; Vector + the whole edge-node stack run on one laptop. Production: cloud zone on sovereign infra (k3s / KubeEdge); Vector stays at the gateway." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;align=left;verticalAlign=middle;fontSize=11;spacingLeft=10;" vertex="1" parent="1">
      <mxGeometry x="40" y="688" width="1320" height="62" as="geometry"/>
    </mxCell>

