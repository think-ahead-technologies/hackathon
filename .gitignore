__pycache__/
*.pyc
.pytest_cache/
.venv/

# macOS / editor cruft
.DS_Store
*.swp
.vscode/
.idea/

# model pipeline: private signing key + build outputs (keep cosign.pub for verification)
pipeline/cosign.key
pipeline/build/
# artifacts pulled from the registry for device delivery (regenerated by `make deploy-artifact`)
pipeline/pull/
# zot TLS cert/key (throwaway, local demo registry) — regenerate with `make keygen`
pipeline/certs/

# firmware: host build outputs (regenerated by `make`)
firmware/build/

# firmware-app: ModusToolbox build + dependency artifacts (regenerated by getlibs/build)
firmware-app/**/build/
firmware-app/**/libs/
firmware-app/**/.mtbqueryapi
firmware-app/**/GeneratedSource/
firmware-app/backups/
# shared library cache, if getlibs runs with the default (repo-local) shared path
/mtb_shared/

# wear detector: training/export outputs (regenerated by `make` in wear_detector/export)
wear_detector/export/build/
