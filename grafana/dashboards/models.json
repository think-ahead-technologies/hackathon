                  { "type": "value", "options": { "deployed": { "color": "#534AB7", "index": 1 } } }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          }
        ]
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "ts", "desc": true }] }
