      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescale" },
          "rawQuery": true,
          "format": "table",
          "rawSql": "SELECT count(*) AS value FROM labels WHERE label <> 'dismiss'"
